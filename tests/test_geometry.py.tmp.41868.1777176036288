"""
Tests for geometry.py — roundabout geometry extraction and defaults.
OSM network calls are mocked so tests run offline.
"""

import os
import sys
import pytest
from unittest.mock import patch, MagicMock
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

from geometry import (
    _apply_defaults, _assign_orientations, _parse_lanes,
    RoundaboutGeometry, LegGeometry, DEFAULTS,
)


# ---------------------------------------------------------------------------
# _apply_defaults
# ---------------------------------------------------------------------------
class TestApplyDefaults:
    def test_single_lane_three_legs(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=3,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "single_lane")
        assert len(result.legs) == 3
        assert all(leg.n_entry_lanes == 1 for leg in result.legs)
        assert all(leg.n_circ_lanes == 1 for leg in result.legs)
        assert all(leg.circulating_width_m == 7.0 for leg in result.legs)

    def test_four_leg_default(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=4,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "single_lane")
        assert len(result.legs) == 4

    def test_hybrid_config(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=4,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "hybrid")
        d = DEFAULTS["hybrid"]
        assert all(leg.n_entry_lanes == d["n_entry_lanes"] for leg in result.legs)

    def test_two_lane_config(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=4,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "two_lane")
        d = DEFAULTS["two_lane"]
        assert all(leg.circulating_width_m == d["circulating_width_m"]
                   for leg in result.legs)

    def test_source_is_defaults(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=3,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "single_lane")
        assert all(leg.source == "defaults" for leg in result.legs)

    def test_unknown_config_falls_back_to_single(self):
        geom = RoundaboutGeometry(site_id="TEST", n_legs=3,
                                   lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "nonexistent_config")
        assert len(result.legs) == 3


# ---------------------------------------------------------------------------
# _assign_orientations
# ---------------------------------------------------------------------------
class TestAssignOrientations:
    def _make_graph(self, center, neighbors):
        """Build a minimal mock graph."""
        G = MagicMock()
        edges = []
        for nb in neighbors:
            G.nodes.__getitem__ = lambda self, n: {"x": n[1], "y": n[0]}
            edges.append((center, nb, {}))
        return G, edges

    def test_three_legs_returns_three(self):
        G = MagicMock()
        G.nodes = {
            0: {"x": -122.0, "y": 37.0},
            1: {"x": -122.01, "y": 37.01},
            2: {"x": -121.99, "y": 37.01},
            3: {"x": -122.0, "y": 36.99},
        }
        neighbors = {1, 2, 3}
        result = _assign_orientations(G, 0, neighbors)
        assert len(result) == 3

    def test_four_legs_returns_four(self):
        G = MagicMock()
        G.nodes = {
            0: {"x": -122.0, "y": 37.0},
            1: {"x": -122.01, "y": 37.0},
            2: {"x": -121.99, "y": 37.0},
            3: {"x": -122.0, "y": 37.01},
            4: {"x": -122.0, "y": 36.99},
        }
        neighbors = {1, 2, 3, 4}
        result = _assign_orientations(G, 0, neighbors)
        assert len(result) == 4

    def test_orientations_in_valid_range(self):
        G = MagicMock()
        G.nodes = {
            0: {"x": -122.0, "y": 37.0},
            1: {"x": -122.01, "y": 37.01},
            2: {"x": -121.99, "y": 37.01},
            3: {"x": -122.0, "y": 36.99},
        }
        neighbors = {1, 2, 3}
        result = _assign_orientations(G, 0, neighbors)
        for ori in result.values():
            assert 0 <= ori <= 7


# ---------------------------------------------------------------------------
# _parse_lanes
# ---------------------------------------------------------------------------
class TestParseLanes:
    def test_numeric_lanes(self):
        assert _parse_lanes({"lanes": "2"}, default=1) == 2

    def test_missing_returns_default(self):
        assert _parse_lanes({}, default=1) == 1

    def test_invalid_returns_default(self):
        assert _parse_lanes({"lanes": "yes"}, default=1) == 1

    def test_zero_returns_default(self):
        assert _parse_lanes({"lanes": "0"}, default=1) == 1

    def test_negative_returns_default(self):
        assert _parse_lanes({"lanes": "-1"}, default=1) == 1


# ---------------------------------------------------------------------------
# get_roundabout_geometry — integration smoke test (mocked OSM)
# ---------------------------------------------------------------------------
class TestGetRoundaboutGeometry:
    @patch("geometry.ox")
    def test_falls_back_to_defaults_on_osm_error(self, mock_ox):
        from geometry import get_roundabout_geometry
        mock_ox.graph_from_point.side_effect = Exception("Network error")
        geom = get_roundabout_geometry(
            site_id="TEST", lat=37.0, lon=-122.0,
            n_legs=3, lane_config="single_lane",
        )
        assert len(geom.legs) == 3
        assert "default" in geom.notes.lower() or "osm" in geom.notes.lower() or geom.notes == ""

    def test_defaults_geometry_valid(self):
        from geometry import _apply_defaults, RoundaboutGeometry
        geom = RoundaboutGeometry(site_id="S1", n_legs=4, lat=37.0, lon=-122.0)
        result = _apply_defaults(geom, "single_lane")
        for leg in result.legs:
            assert leg.n_entry_lanes >= 1
            assert leg.n_circ_lanes >= 1
            assert leg.circulating_width_m > 0
            assert leg.entry_radius_m > 0
            assert 0 <= leg.entry_angle_deg <= 90
